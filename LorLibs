-- UTIL
-- ══════════════════════════════════════════════════
local function new(cls, props, parent)
    local i = Instance.new(cls)
    for k, v in pairs(props or {}) do i[k] = v end
    if parent then i.Parent = parent end
    return i
end

local function tw(obj, props, info)
    if not obj or not obj.Parent then return end
    TS:Create(obj, info or ANIM, props):Play()
end

local function stroke(parent, col, thick)
    return new("UIStroke", {
        Color           = col   or T.BORDER,
        Thickness       = thick or 1,
        LineJoinMode    = Enum.LineJoinMode.Miter,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    }, parent)
end

local function listLayout(parent, padding)
    return new("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, padding or 0),
    }, parent)
end

local function pad(parent, t, r, b, l)
    return new("UIPadding", {
        PaddingTop    = UDim.new(0, t or 6),
        PaddingRight  = UDim.new(0, r or 8),
        PaddingBottom = UDim.new(0, b or 6),
        PaddingLeft   = UDim.new(0, l or 8),
    }, parent)
end

-- LoR corner clip — uses UIGradient to fake diagonal cut, zero extra frames
-- Applies a transparent triangle mask in the corner via ImageLabel
local function clipCorners(frame, size)
    size = size or 6
    -- Use a single Frame overlay in each corner with a rotated gradient
    -- This is much cheaper than spawning Frame + child Frame per corner
    local corners = {"TL","TR","BL","BR"}
    local positions = {
        TL = UDim2.new(0,0,0,0),
        TR = UDim2.new(1,-size,0,0),
        BL = UDim2.new(0,0,1,-size),
        BR = UDim2.new(1,-size,1,-size),
    }
    local rotations = {TL=45, TR=-45, BL=-45, BR=45}

    for _, c in ipairs(corners) do
        local clip = new("Frame", {
            Size             = UDim2.new(0, size, 0, size),
            Position         = positions[c],
            BackgroundColor3 = T.BG,
            BorderSizePixel  = 0,
            ZIndex           = (frame.ZIndex or 1) + 3,
        }, frame)
        -- diagonal line
        new("Frame", {
            Size             = UDim2.new(0, size * 1.5, 0, 1),
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new(0.5, 0, 0.5, 0),
            Rotation         = rotations[c],
            BackgroundColor3 = T.BORDER_DIM,
            BorderSizePixel  = 0,
            ZIndex           = (frame.ZIndex or 1) + 4,
        }, clip)
    end
end

local function safePcall(f, ...) pcall(f, ...) end

-- config helpers
local cfgFolder = "LoRUI"
local HS = game:GetService("HttpService")

local function readCfg(name)
    if not isfile then return nil end
    local path = cfgFolder.."/"..name..".json"
    if not isfile(path) then return nil end
    local ok, d = pcall(function() return HS:JSONDecode(readfile(path)) end)
    return ok and d or nil
end

local function writeCfg(name, data)
    if not writefile then return end
    if not isfolder(cfgFolder) then makefolder(cfgFolder) end
    pcall(function() writefile(cfgFolder.."/"..name..".json", HS:JSONEncode(data)) end)
end

