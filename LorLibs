-- NOTIFICATIONS
-- ══════════════════════════════════════════════════
local notifCount = 0

local function makeNotif(cfg)
    local title    = cfg.Name or cfg.Title or "NOTICE"
    local content  = cfg.Content or cfg.Text or ""
    local duration = cfg.Time or cfg.Duration or 3
    local yOff     = -(notifCount * 72 + 10)
    notifCount     = notifCount + 1

    local N = new("Frame", {
        Size             = UDim2.new(0, 260, 0, 62),
        Position         = UDim2.new(1, 270, 1, yOff),
        BackgroundColor3 = T.BG2,
        BorderSizePixel  = 0,
        ZIndex           = 200,
    }, gui)
    stroke(N, T.BORDER_LIT, 1)
    clipCorners(N, 6)

    new("Frame", {
        Size             = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = T.ACCENT_RED,
        BorderSizePixel  = 0,
        ZIndex           = 201,
    }, N)

    new("TextLabel", {
        Size             = UDim2.new(1,-14,0,22),
        Position         = UDim2.new(0,10,0,6),
        BackgroundTransparency = 1,
        Text             = string.upper(title),
        TextColor3       = T.TEXT_GOLD,
        Font             = Enum.Font.GothamBold,
        TextSize         = 10,
        TextTracking     = 4,
        TextXAlignment   = Enum.TextXAlignment.Left,
        ZIndex           = 201,
    }, N)

    new("TextLabel", {
        Size             = UDim2.new(1,-14,0,28),
        Position         = UDim2.new(0,10,0,28),
        BackgroundTransparency = 1,
        Text             = content,
        TextColor3       = T.TEXT_DIM,
        Font             = Enum.Font.Gotham,
        TextSize         = 10,
        TextWrapped      = true,
        TextXAlignment   = Enum.TextXAlignment.Left,
        ZIndex           = 201,
    }, N)

    tw(N, {Position = UDim2.new(1,-270,1,yOff)}, ANIM2)
    task.delay(duration, function()
        tw(N, {Position = UDim2.new(1,270,1,yOff)}, ANIM2)
        task.wait(0.3)
        notifCount = math.max(0, notifCount - 1)
        N:Destroy()
    end)
end

function LoRUI:Notify(cfg)           makeNotif(cfg) end
function LoRUI:MakeNotification(cfg) makeNotif(cfg) end

