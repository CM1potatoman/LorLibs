-- ══════════════════════════════════════════════════
-- GLOBAL INPUT STATE
-- Single handlers shared across ALL sliders/colorpickers
-- ══════════════════════════════════════════════════
local activeSlider = nil  -- {track, fill, handle, min, max, inc, suf, valLbl, flag, cb}
local activeCP     = nil  -- {track, fill, handle, onChange}

UIS.InputChanged:Connect(function(inp)
    if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
    if activeSlider then
        local s = activeSlider
        local ax = s.track.AbsolutePosition.X
        local aw = s.track.AbsoluteSize.X
        local p  = math.clamp((inp.Position.X - ax) / aw, 0, 1)
        local raw = s.min + (s.max - s.min) * p
        local v  = math.clamp(math.floor(raw / s.inc + 0.5) * s.inc, s.min, s.max)
        v = math.floor(v * 100000 + 0.5) / 100000
        s.val[1] = v
        local fp = (v - s.min) / (s.max - s.min)
        s.fill.Size       = UDim2.new(fp, 0, 1, 0)
        s.handle.Position = UDim2.new(fp, 0, 0.5, 0)
        s.valLbl.Text     = tostring(v) .. s.suf
        if s.flag then LoRUI.Flags[s.flag] = LoRUI.Flags[s.flag] or {}; LoRUI.Flags[s.flag].Value = v end
        if s.cb then pcall(s.cb, v) end
    end
    if activeCP then
        local c = activeCP
        local ax = c.track.AbsolutePosition.X
        local aw = c.track.AbsoluteSize.X
        local p  = math.clamp((inp.Position.X - ax) / aw, 0, 1)
        c.fill.Size       = UDim2.new(p, 0, 1, 0)
        c.handle.Position = UDim2.new(p, 0, 0.5, 0)
        c.onChange(math.floor(p * 255))
    end
end)

UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        activeSlider = nil
        activeCP     = nil
    end
end)

